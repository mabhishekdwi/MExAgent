<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#CC1A1A2E"
    android:elevation="16dp">

    <!-- ── Collapsed header (always visible, tap to toggle) ── -->
    <LinearLayout
        android:id="@+id/llHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="6dp">

        <!-- Status dot -->
        <TextView
            android:id="@+id/tvStatusDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="#4CAF50"
            android:layout_marginEnd="6dp" />

        <!-- Status label -->
        <TextView
            android:id="@+id/tvOverlayStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Idle"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:layout_marginEnd="4dp" />

        <!-- Expand/Collapse toggle -->
        <Button
            android:id="@+id/btnToggle"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="&#9660;"
            android:textColor="#BBBBBB"
            android:textSize="12sp"
            android:background="@android:color/transparent"
            android:padding="0dp"
            android:contentDescription="Toggle" />
    </LinearLayout>

    <!-- ── Expanded buttons (hidden when collapsed) ── -->
    <LinearLayout
        android:id="@+id/llButtons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingBottom="6dp"
        android:visibility="gone">

        <!-- Start -->
        <Button
            android:id="@+id/btnOverlayStart"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="&#9654;"
            android:textColor="#4CAF50"
            android:textSize="18sp"
            android:background="@android:color/transparent"
            android:padding="0dp"
            android:contentDescription="Start" />

        <!-- Stop -->
        <Button
            android:id="@+id/btnOverlayStop"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="&#9646;"
            android:textColor="#F44336"
            android:textSize="18sp"
            android:background="@android:color/transparent"
            android:padding="0dp"
            android:enabled="false"
            android:alpha="0.5"
            android:contentDescription="Stop" />

        <!-- Logs -->
        <Button
            android:id="@+id/btnOverlayLogs"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="&#128203;"
            android:textSize="16sp"
            android:background="@android:color/transparent"
            android:padding="0dp"
            android:contentDescription="Logs" />

        <!-- Settings -->
        <Button
            android:id="@+id/btnOverlaySettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="&#9881;"
            android:textColor="#9E9E9E"
            android:textSize="16sp"
            android:background="@android:color/transparent"
            android:padding="0dp"
            android:contentDescription="Settings" />

        <!-- Quit -->
        <Button
            android:id="@+id/btnOverlayQuit"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="&#10005;"
            android:textColor="#FF5252"
            android:textSize="16sp"
            android:background="@android:color/transparent"
            android:padding="0dp"
            android:contentDescription="Quit" />

    </LinearLayout>

</LinearLayout>
