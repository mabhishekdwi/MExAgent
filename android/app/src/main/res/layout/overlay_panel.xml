<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#CC1A1A2E"
    android:padding="8dp"
    android:elevation="16dp">

    <TextView
        android:id="@+id/tvOverlayStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Idle"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:gravity="center"
        android:paddingBottom="4dp" />

    <!-- Start -->
    <Button
        android:id="@+id/btnOverlayStart"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:text="&#9654;"
        android:textColor="#4CAF50"
        android:textSize="20sp"
        android:background="@android:color/transparent"
        android:padding="0dp"
        android:contentDescription="Start" />

    <!-- Stop -->
    <Button
        android:id="@+id/btnOverlayStop"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:text="&#9646;"
        android:textColor="#F44336"
        android:textSize="20sp"
        android:background="@android:color/transparent"
        android:padding="0dp"
        android:enabled="false"
        android:alpha="0.5"
        android:contentDescription="Stop" />

    <!-- Logs -->
    <Button
        android:id="@+id/btnOverlayLogs"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:text="&#128203;"
        android:textSize="18sp"
        android:background="@android:color/transparent"
        android:padding="0dp"
        android:contentDescription="Logs" />

    <!-- Settings -->
    <Button
        android:id="@+id/btnOverlaySettings"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:text="&#9881;"
        android:textColor="#9E9E9E"
        android:textSize="18sp"
        android:background="@android:color/transparent"
        android:padding="0dp"
        android:contentDescription="Settings" />

</LinearLayout>
