# Appium
APPIUM_URL=http://localhost:4723
APPIUM_TIMEOUT=30

# LLM  — choose: groq | ollama
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# Ollama (only used when LLM_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Agent
DEFAULT_DEPTH=2
MAX_ACTIONS_PER_SCREEN=10
ACTION_DELAY_MS=800

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false
